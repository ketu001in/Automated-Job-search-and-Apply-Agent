
# ── Optional ──────────────────────────────────────────────────────────────────
# Port for the web dashboard (default 3000)
PORT=3000

# Set to "true" to show the browser window while the agent runs (useful for debugging)
# Set to "false" (or omit) for headless / server deployment
HEADLESS=false

# Schedule: runs at 10:00 AM IST every day by default (cron in IST)
# To change, edit CRON_SCHEDULE using standard cron syntax
CRON_SCHEDULE=0 10 * * *

# LinkedIn credentials (optional — agent can also use saved cookies)
# If provided, agent will log in automatically on first run
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
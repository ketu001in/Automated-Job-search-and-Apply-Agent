# ── No API key required — agent runs fully free ───────────────────────────────

# Port for the web dashboard (default 3000)
PORT=3000

# Set to "false" to show browser window (needed for first LinkedIn login)
# Set to "true" for silent background mode after first login
HEADLESS=false

# Schedule: runs at 10:00 AM IST every day
CRON_SCHEDULE=0 10 * * *

# LinkedIn credentials (optional — agent can also wait for manual login)
# If set, agent logs in automatically. Leave blank to log in manually.
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
